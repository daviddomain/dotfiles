# ── Powerlevel10k instant prompt (muss ganz oben bleiben) ──
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"

# Nur Plugins aktivieren, deren zugehörige Programme in der Umgebung existieren.
plugins=(git z extract)
(( $+commands[npm] )) && plugins+=(npm)
(( $+commands[node] )) && plugins+=(node)
(( $+commands[docker] )) && plugins+=(docker)
(( $+commands[sudo] )) && plugins+=(sudo)

plugins+=(zsh-autosuggestions)

# History nur dann ins Claude-Verzeichnis legen, wenn es ein echter Mount ist.
# Ein lediglich vorhandener Ordner wäre bei einem Rebuild weiterhin ephemer.
_dotfiles_claude_is_mount=0
if [[ -f /.dockerenv && -d /workspaces && -d "$HOME/.claude" && -w "$HOME/.claude" ]]; then
  if (( $+commands[mountpoint] )) && mountpoint -q "$HOME/.claude"; then
    _dotfiles_claude_is_mount=1
  elif (( $+commands[findmnt] )) && [[ "$(findmnt -n -o TARGET -T "$HOME/.claude" 2>/dev/null)" == "$HOME/.claude" ]]; then
    _dotfiles_claude_is_mount=1
  fi
fi

if (( _dotfiles_claude_is_mount )); then
  export HISTFILE="$HOME/.claude/.shell/zsh_history"
  [[ -d "${HISTFILE:h}" ]] || mkdir -p "${HISTFILE:h}"
fi
unset _dotfiles_claude_is_mount

source "$ZSH/oh-my-zsh.sh"

# Keine Befehle mit führendem Leerzeichen in der persistenten History speichern.
setopt HIST_IGNORE_SPACE HIST_REDUCE_BLANKS

# ── Optionale, im jeweiligen Image vorhandene Shell-Integrationen ──
if (( $+commands[direnv] )); then
  eval "$(direnv hook zsh)"
fi

if (( $+commands[fzf] )) && [[ -t 0 && -t 1 ]]; then
  if fzf --zsh >/dev/null 2>&1; then
    source <(fzf --zsh)
  else
    [[ -r /usr/share/doc/fzf/examples/key-bindings.zsh ]] && source /usr/share/doc/fzf/examples/key-bindings.zsh
    [[ -r /usr/share/doc/fzf/examples/completion.zsh ]] && source /usr/share/doc/fzf/examples/completion.zsh
  fi
fi

if (( $+commands[gh] )); then
  eval "$(gh completion -s zsh)"
fi

# ── Aliases ──
(( $+commands[docker] )) && alias containernames='docker ps --format "{{.Names}}"'
(( $+commands[npm] )) && alias n='npm'

# ── nvm (nur laden, wenn vorhanden) ──
export NVM_DIR="$HOME/.nvm"
[[ -s "$NVM_DIR/nvm.sh" ]] && source "$NVM_DIR/nvm.sh"
[[ -s "$NVM_DIR/bash_completion" ]] && source "$NVM_DIR/bash_completion"

# ── Prompt-Konfiguration ──
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ── Maschinenspezifisches, nicht versioniert ──
[[ ! -f ~/.zshrc.local ]] || source ~/.zshrc.local

# Muss nach allen Widget- und Completion-Integrationen geladen werden.
source "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

# VS Code Remote-Container: Shell-Integration laden, wenn verfügbar.
[[ "$TERM_PROGRAM" == "vscode" ]] && . "$(code --locate-shell-integration-path zsh)"

